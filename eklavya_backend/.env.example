# Eklavya.AI Backend — Environment Variables
# Copy this file to .env and fill in your Supabase credentials.
# See docs/SUPABASE_SETUP.md for detailed instructions.

# ─── Database ───────────────────────────────────────────────
# Supabase PostgreSQL connection string.
# Transaction pooler typically uses port 6543. Session mode may use 5432 depending on project settings.
# Find at: Supabase Dashboard → Settings → Database → Connection string
# IMPORTANT: Replace the postgresql:// prefix with postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?ssl=require

# ─── Supabase Auth ──────────────────────────────────────────
# Project URL — Find at: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://[PROJECT_REF].supabase.co

# Anon (public) key — Find at: Supabase Dashboard → Settings → API → anon public
SUPABASE_ANON_KEY=eyJ...your-anon-key-here

# JWT Secret (legacy HS256 projects) — Find at: Supabase Dashboard → Settings → API → JWT Settings
JWT_SECRET=your-jwt-secret-here

# Optional public key for RS256/ES256 projects (PEM format).
# If empty, backend fetches signing keys from Supabase JWKS automatically.
SUPABASE_JWT_PUBLIC_KEY=

# ─── App ────────────────────────────────────────────────────
ENVIRONMENT=development

# ─── Google Gemini ──────────────────────────────────────────
# API key for the Guru Agent. Get at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
